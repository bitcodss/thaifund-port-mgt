# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=thaiund
POSTGRES_USER=thaiuser
POSTGRES_PASSWORD=changeme_strong_password

# ── Backend ───────────────────────────────────────────────────────────────────
# Host is the Docker service name when running inside Compose
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Generate with: openssl rand -hex 32
SECRET_KEY=changeme_generate_with_openssl_rand_hex_32

ACCESS_TOKEN_EXPIRE_MINUTES=1440

# First admin user — created on startup if no users exist
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=changeme_admin_password

# SEC Thailand Open Data API (required for Phase 2 data sync)
# Subscribe at: https://api-portal.sec.or.th/
SEC_API_KEY=               # Fund Daily Info API key (NAV + dividends)
SEC_FACTSHEET_KEY=         # Fund Factsheet API key (fund metadata + proj_id discovery)

# Optional secondary SEC key for failover
SEC_API_KEY_SECONDARY=

# ── Ollama (AI summaries) ─────────────────────────────────────────────────────
# Ollama must be running on the host. docker-internal resolves to host from container.
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma4:26b

# ── Finnomena (fallback — rarely needed) ─────────────────────────────────────
# Used only if Eastspring ES- funds are unavailable via SEC API
FINNOMENA_EMAIL=
FINNOMENA_PASSWORD=

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL the browser uses to reach the backend API
NEXT_PUBLIC_API_URL=http://localhost:8000
